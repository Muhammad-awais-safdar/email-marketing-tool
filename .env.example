APP_NAME="EmailMarketingTool"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

# LOGGING
LOG_CHANNEL=daily
LOG_LEVEL=info

# DATABASE (Update with your production DB)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=email_marketing
DB_USERNAME=root
DB_PASSWORD=

# QUEUE & CACHE (Redis is highly recommended for production performance)
QUEUE_CONNECTION=database
CACHE_STORE=database

# MAIL (Finalize with your SMTP provider)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# VITE
VITE_APP_NAME="${APP_NAME}"
VITE_API_URL="https://your-domain.com/api"
